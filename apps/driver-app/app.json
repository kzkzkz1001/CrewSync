{
  "expo": {
    "name": "CrewSync Driver",
    "slug": "crewsync-driver",
    "version": "1.0.0",
    "scheme": "crewsync-driver",
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CrewSync needs your location to share your position with the team."
        }
      ]
    ],
    "android": {
      "config": {
        "googleMaps": { "apiKey": "YOUR_GOOGLE_MAPS_API_KEY" }
      }
    },
    "extra": {
      "gatewayUrl": "http://localhost:3000"
    }
  }
}
